# Clicky Windows environment variables.
# Copy this file to .env and fill in your values. Never commit .env to git.

# Anthropic/OpenRouter API key (required)
# Option A (recommended — BYOK, model-agnostic): use your OpenRouter key (sk-or-v1-...)
# and also set ANTHROPIC_BASE_URL=https://openrouter.ai/api for Claude routing.
#   Get one at https://openrouter.ai/
# Option B (Anthropic-direct): use an Anthropic-issued key (sk-ant-...) and leave
# ANTHROPIC_BASE_URL unset.
#   Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-openrouter-or-anthropic-key-here
ANTHROPIC_BASE_URL=https://openrouter.ai/api
# AssemblyAI API key (required — streaming STT via u3-rt-pro WebSocket)
# Sign up at https://www.assemblyai.com/dashboard/signup — $50 in free credits, no credit card.
# After login, dashboard home shows "Your API Keys" card; copy the key.
ASSEMBLYAI_API_KEY=your-assemblyai-key-here


# Cartesia API key (required — streaming TTS via Sonic-3 WebSocket)
# Sign up at https://play.cartesia.ai/sign-in — 20k free credits/month, no credit card.
# Left sidebar → API Keys → New Key → name it "peep-dev" → copy.
# Key format: starts with "sk_car_..."
CARTESIA_API_KEY=your-cartesia-key-here

# Optional overrides (defaults live in config.py):
# HOTKEY=ctrl+alt+space           # Phase 1 default. Pivoted from Ctrl+Shift+Space (Excel Select-All conflict) and Alt+Space (Windows menu + Copilot). NEVER ctrl+space (VS Code IntelliSense). Phase 1.5 may restore Alt+Space via Win32 RegisterHotKey subclass.
#
MODEL_ID=google/gemini-3-flash-preview
# ^ Phase 1.5 default — Gemini 3 Flash Preview via OpenRouter OpenAI-compat endpoint.
# ~50% faster vision TTFT than Claude Sonnet 4.6 (+57 points on UI navigation
# benchmarks per Google's Gemini 3 release notes). Same price as Google direct
# (OpenRouter no markup). Aaron InspireCon 2026-04 explicit recommendation.
#
# Alternative: MODEL_ID=anthropic/claude-sonnet-4-6 (slower but proven on
# Phase 1 tester machine). Any OpenRouter model_id with 'google/' or
# 'anthropic/' prefix works — ai.py's create_ai_client() routes automatically.
#
# See DECISIONS.md 2026-04-19 'Gemini 3 Flash via OpenRouter'.
#
# CARTESIA_VOICE_ID=              # Cartesia voice ID — default hardcoded in tts.py. Change to swap voice.
# MEMORY_DIR=                     # Defaults to ~/.peep/memory/
